#!/bin/bash
#==========================================================
#
#       FILE:           bin/ciclogger
#       USAGE:          log [LEVEL] {MESSAGE} 
#       DESCRIPTION:    Standardize log handling for custom CIC scripts
#
#       AUTHOR:         MXHML (mxhml@proton.me)
#       VERSION:        1.0.1
#       CREATED:        July 2, 2026
#       REVISION:       1
#
#==========================================================
# This script also defines some common tput(1) formatting variables

BO=$(tput bold)
ULIN=$(tput smul)
NOFO=$(tput sgr0)
ITAL=$(tput sitm)
DIM=$(tput dim)
RED=$(tput setaf 1)
GR=$(tput setaf 2)

UPTIME=$(cat /proc/uptime | awk '{print $1}')

# log [LEVEL] message
log(){
    #are we being piped?
    if [[ ! -t 1 ]]; then
        #Script output is being piped to another command or file
        :
    else
        #we are NOT being piped
        :
    fi

    case $1 in
        info)
             lecolor="$GR"
        ;;
        error)
             lecolor="$RED"
        ;;
    esac

    printf "%s (${DIM}%s${NOFO})[${BO}${lecolor}%s${NOFO}]: %b\n" "$UPTIME" "${FUNCNAME[1]}" "${1^^}" "${2}" 
}
export BO ULIN NOFO ITAL DIM log